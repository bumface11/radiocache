{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Radio Cache Dev Server",
			"type": "shell",
			"command": "uv",
			"args": [
				"run",
				"uvicorn",
				"radio_cache_api:app",
				"--reload",
				"--reload-dir",
				".",
				"--reload-include",
				"*.json"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
	]
}