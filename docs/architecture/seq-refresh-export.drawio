<mxfile host="draw.io" type="device">

  <!-- ================================================================ -->
  <!-- PAGE 1: POST /api/refresh — Trigger Cache Refresh                 -->
  <!-- ================================================================ -->
  <diagram name="POST /api/refresh" id="seq-refresh-trigger">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;POST /api/refresh&lt;/b&gt;  —  Trigger Background Cache Refresh" style="text;html=1;fontSize=16;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="600" height="30" as="geometry"/>
        </mxCell>
        <!-- Participants -->
        <mxCell id="p1" value="Client" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="60" y="50" width="120" height="750" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="FastAPI&lt;br&gt;api_refresh()" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="260" y="50" width="120" height="750" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="refresh.py&lt;br&gt;(bg thread)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#B5D6F0;strokeColor=#5B8DB8;" vertex="1" parent="1">
          <mxGeometry x="460" y="50" width="120" height="750" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="bbc_feed&lt;br&gt;_parser.py" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#B5D6F0;strokeColor=#5B8DB8;" vertex="1" parent="1">
          <mxGeometry x="660" y="50" width="120" height="750" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="BBC RMS&lt;br&gt;API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="860" y="50" width="120" height="750" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="CacheDB" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="1060" y="50" width="120" height="750" as="geometry"/>
        </mxCell>

        <!-- Synchronous part: accept request -->
        <mxCell id="m1" value="1. POST /api/refresh?categories=drama,thriller" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="120" as="sourcePoint"/><mxPoint x="320" y="120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="n1" value="Check _refresh_thread&lt;br&gt;not already running" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#E6E6E6;strokeColor=#999999;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="350" y="130" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="2. spawn background thread → refresh_cache(categories)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="190" as="sourcePoint"/><mxPoint x="520" y="190" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="3. 202 Accepted {status: &quot;started&quot;}" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="230" as="sourcePoint"/><mxPoint x="120" y="230" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Async part: background refresh -->
        <mxCell id="async_frame" value="async" style="shape=umlFrame;whiteSpace=wrap;html=1;width=40;height=20;fillColor=none;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="260" width="820" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="async_label" value="[Background Thread]" style="text;html=1;fontSize=10;fontStyle=2;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="450" y="260" width="140" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="m4" value="4. fetch_drama_programmes(slugs)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="310" as="sourcePoint"/><mxPoint x="720" y="310" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Loop frame for pagination -->
        <mxCell id="loop1" value="loop" style="shape=umlFrame;whiteSpace=wrap;html=1;width=40;height=20;fillColor=none;strokeColor=#AAAAAA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="330" width="400" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="loop1l" value="[for each category slug + paginated pages]" style="text;html=1;fontSize=9;fontStyle=2;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="670" y="330" width="230" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="m5" value="5. GET /rms/playable?category={slug}&amp;offset=N" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="720" y="370" as="sourcePoint"/><mxPoint x="920" y="370" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="JSON programmes page" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="920" y="400" as="sourcePoint"/><mxPoint x="720" y="400" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="6. _parse_programme_item() → Programme" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="720" y="440" as="sourcePoint"/><mxPoint x="720" y="440" as="targetPoint"/>
            <Array as="points"><mxPoint x="780" y="440"/><mxPoint x="780" y="455"/><mxPoint x="720" y="455"/></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m8" value="list[Programme] (de-duped, categories merged)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="720" y="490" as="sourcePoint"/><mxPoint x="520" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m9" value="7. db.upsert_programmes(programmes)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="530" as="sourcePoint"/><mxPoint x="1120" y="530" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m10" value="8. db._rebuild_categories()" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="570" as="sourcePoint"/><mxPoint x="1120" y="570" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m11" value="9. db.purge_expired()" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="610" as="sourcePoint"/><mxPoint x="1120" y="610" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m12" value="10. _export_json() → radio_cache_export.json" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="650" as="sourcePoint"/><mxPoint x="1120" y="650" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m13" value="11. _export_get_iplayer_cache()" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="690" as="sourcePoint"/><mxPoint x="1120" y="690" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ================================================================ -->
  <!-- PAGE 2: GET /api/refresh/status                                   -->
  <!-- ================================================================ -->
  <diagram name="GET /api/refresh/status" id="seq-refresh-status">
    <mxGraphModel dx="700" dy="400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="350" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;GET /api/refresh/status&lt;/b&gt;  —  Check Refresh State" style="text;html=1;fontSize=16;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="500" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1" value="Client" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="80" y="50" width="120" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="FastAPI&lt;br&gt;api_refresh_status()" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="140" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="1. GET /api/refresh/status" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="120" as="sourcePoint"/><mxPoint x="420" y="120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="n1" value="Checks _refresh_thread&lt;br&gt;is not None and is_alive()" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#E6E6E6;strokeColor=#999999;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="500" y="130" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="2. JSON {running: true/false}" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="200" as="sourcePoint"/><mxPoint x="140" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ================================================================ -->
  <!-- PAGE 3: GET /refresh/categories (UI) +                            -->
  <!--         GET /api/refresh/categories (SSE)                         -->
  <!-- ================================================================ -->
  <diagram name="GET /api/refresh/categories (SSE)" id="seq-refresh-categories">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;GET /api/refresh/categories&lt;/b&gt;  —  SSE Category Count Stream" style="text;html=1;fontSize=16;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="600" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1" value="Browser&lt;br&gt;(EventSource)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="60" y="50" width="120" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="FastAPI&lt;br&gt;api_refresh_&lt;br&gt;categories()" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="280" y="50" width="120" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="bbc_feed&lt;br&gt;_parser.py" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#B5D6F0;strokeColor=#5B8DB8;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="120" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="BBC RMS&lt;br&gt;API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="720" y="50" width="120" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="1. GET /api/refresh/categories (Accept: text/event-stream)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="120" y="120" as="sourcePoint"/><mxPoint x="340" y="120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="2. fetch_category_counts()" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="160" as="sourcePoint"/><mxPoint x="560" y="160" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="3. fetch_all_category_slugs()" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="200" as="sourcePoint"/><mxPoint x="780" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="category slugs" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="230" as="sourcePoint"/><mxPoint x="560" y="230" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Loop for each category -->
        <mxCell id="loop1" value="loop" style="shape=umlFrame;whiteSpace=wrap;html=1;width=40;height=20;fillColor=none;strokeColor=#AAAAAA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="260" width="750" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="loop1l" value="[for each category slug]" style="text;html=1;fontSize=9;fontStyle=2;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="150" y="260" width="150" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="m5" value="4. fetch_category_count(slug)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="300" as="sourcePoint"/><mxPoint x="560" y="300" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="5. GET /rms/playable?category={slug}" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="340" as="sourcePoint"/><mxPoint x="780" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="{count: N}" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="370" as="sourcePoint"/><mxPoint x="560" y="370" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m8" value="6. SSE: data: {slug, name, count}" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;strokeColor=#CC6600;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="420" as="sourcePoint"/><mxPoint x="120" y="420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m9" value="7. SSE: event: done" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=10;strokeColor=#CC6600;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="490" as="sourcePoint"/><mxPoint x="120" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

