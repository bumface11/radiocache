          </mxGeometry>
        </mxCell>
        <mxCell id="m5" value="4. 201 Created {job_id, status: queued}" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="270" as="sourcePoint"/><mxPoint x="90" y="270" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Async: Background worker processes job -->
        <mxCell id="async_frame" value="async" style="shape=umlFrame;whiteSpace=wrap;html=1;width=40;height=20;fillColor=none;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
