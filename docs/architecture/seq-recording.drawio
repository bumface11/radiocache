          <mxGeometry x="190" y="475" width="1010" height="10" as="geometry"/>
        </mxCell>
        <mxCell id="alt1b" value="[source_type = &quot;programme&quot;]" style="text;html=1;fontSize=9;fontStyle=2;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="230" y="480" width="170" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="m9" value="6b. resolve_programme_stream(pid)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="510" as="sourcePoint"/><mxPoint x="610" y="510" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m10" value="7. iBL API → version PIDs → Media Selector" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
