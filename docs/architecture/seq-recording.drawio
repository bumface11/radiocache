            <mxPoint x="250" y="860" as="sourcePoint"/><mxPoint x="430" y="860" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Completion -->
        <mxCell id="m18" value="12. recording complete → status=completed, output_path set" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="930" as="sourcePoint"/><mxPoint x="430" y="930" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
