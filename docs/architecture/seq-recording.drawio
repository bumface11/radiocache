  <!-- ================================================================ -->
  <!-- PAGE 1: POST /api/recordings — Create Recording Job               -->
  <!-- ================================================================ -->
  <diagram name="POST /api/recordings (Create)" id="seq-rec-create">
    <mxGraphModel dx="1300" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
