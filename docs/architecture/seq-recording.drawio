          </mxGeometry>
        </mxCell>
        <mxCell id="m11" value="HLS manifest URL (non-DRM)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1130" y="565" as="sourcePoint"/><mxPoint x="250" y="565" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Metadata lookup for programme -->
        <mxCell id="m12" value="8. db.get_programme(pid) → metadata for tags" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="610" as="sourcePoint"/><mxPoint x="780" y="610" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m13" value="Programme (title, series, channel, thumbnail...)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="640" as="sourcePoint"/><mxPoint x="250" y="640" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Build output path + record -->
        <mxCell id="m14" value="9. build_output_path(job, title) → recordings/timestamped.m4a" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="680" as="sourcePoint"/><mxPoint x="950" y="680" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m15" value="10. record_stream(job, manifest_url, path, duration, format, metadata)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="720" as="sourcePoint"/><mxPoint x="950" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="n2" value="Builds ffmpeg command:&lt;br&gt;-reconnect, -c:a copy,&lt;br&gt;-metadata, cover art,&lt;br&gt;-movflags +faststart" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#E6E6E6;strokeColor=#999999;fontSize=8;align=left;" vertex="1" parent="1">
          <mxGeometry x="1000" y="720" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Loop: ffmpeg progress -->
        <mxCell id="loop1" value="loop" style="shape=umlFrame;whiteSpace=wrap;html=1;width=35;height=16;fillColor=none;strokeColor=#AAAAAA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="790" width="870" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="loop1l" value="[ffmpeg subprocess running, parsing stderr]" style="text;html=1;fontSize=8;fontStyle=2;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="245" y="790" width="230" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="m16" value="11. progress_callback(time=HH:MM:SS)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
