  <!-- ================================================================ -->
  <!-- PAGE 4: GET /api/recordings/{job_id} — Single Job                 -->
  <!-- ================================================================ -->
  <diagram name="GET /api/recordings/{job_id}" id="seq-rec-get">
    <mxGraphModel dx="800" dy="450" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="380" math="0" shadow="0">
