          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="RecordingJob (status=queued)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
