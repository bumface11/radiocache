          </mxGeometry>
        </mxCell>
        <mxCell id="m8" value="ResolvedStream (Akamai HLS URL)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="610" y="450" as="sourcePoint"/><mxPoint x="250" y="450" as="targetPoint"/>
