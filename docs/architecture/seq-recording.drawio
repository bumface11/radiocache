          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="3. _ensure_recording_worker() → start daemon thread if needed" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="230" as="sourcePoint"/><mxPoint x="250" y="230" as="targetPoint"/>
