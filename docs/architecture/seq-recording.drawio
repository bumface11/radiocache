        <mxCell id="p4" value="Stream&lt;br&gt;Resolver" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#B5D6F0;strokeColor=#5B8DB8;" vertex="1" parent="1">
          <mxGeometry x="560" y="50" width="100" height="950" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="CacheDB" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="730" y="50" width="100" height="950" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="Recorder&lt;br&gt;(FFmpeg)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#B5D6F0;strokeColor=#5B8DB8;" vertex="1" parent="1">
          <mxGeometry x="900" y="50" width="100" height="950" as="geometry"/>
        </mxCell>
        <mxCell id="p7" value="BBC APIs&lt;br&gt;(external)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="1080" y="50" width="100" height="950" as="geometry"/>
        </mxCell>

        <!-- Synchronous: create job -->
        <mxCell id="m1" value="1. POST /api/recordings {source_type, source_id, duration_seconds, output_format}" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
