        </mxCell>
        <mxCell id="async_label" value="[Background Worker Thread — _run_recording_job()]" style="text;html=1;fontSize=10;fontStyle=2;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="220" y="300" width="300" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="m6" value="5. pop oldest queued job → status=running" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
