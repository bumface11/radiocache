        </mxCell>
        <mxCell id="alt1a" value="[source_type = &quot;live&quot;]" style="text;html=1;fontSize=9;fontStyle=2;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="230" y="380" width="140" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="m7" value="6a. resolve_live_stream(station_id)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;fontSize=9;" edge="1" parent="1">
